# ═══════════════════════════════════════════════════════════════════
# bolt.diy × DTE — Level 5 Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and edit as needed.
# ═══════════════════════════════════════════════════════════════════

# ── Lucy GGUF Model ──────────────────────────────────────────────
LUCY_MODEL_FILE=lucy_128k-Q4_K_M.gguf
LUCY_MODEL_NAME=lucy_128k-Q4_K_M
LUCY_PORT=8081
LUCY_CTX_SIZE=32768
LUCY_THREADS=4
LUCY_BATCH_SIZE=512
LUCY_MAX_PREDICT=2048
LUCY_PARALLEL=1
LUCY_MEM_LIMIT=6G
LUCY_MEM_RESERVE=3G
# For GPU mode, uncomment:
# LUCY_GPU_LAYERS=99

# ── bolt.diy ─────────────────────────────────────────────────────
BOLT_PORT=5173

# ── Echobeats ────────────────────────────────────────────────────
ECHOBEATS_INTERVAL_MS=2000
ECHOBEATS_NUM_STREAMS=3

# ── Reservoir ────────────────────────────────────────────────────
RESERVOIR_UNITS=256
RESERVOIR_SPECTRAL_RADIUS=0.95
RESERVOIR_LEAKING_RATE=0.3
RESERVOIR_INPUT_SCALING=0.5

# ── RLS Online Learning ─────────────────────────────────────────
RLS_FORGETTING_FACTOR=0.995
RLS_REGULARIZATION=0.01

# ── Self-Modification Safety ────────────────────────────────────
SELFMOD_MAX_PER_MINUTE=10
SELFMOD_DEAD_MAN_THRESHOLD=0.2
SELFMOD_COOLDOWN_MS=60000

# ── Telemetry ────────────────────────────────────────────────────
TELEMETRY_PORT=9464
TELEMETRY_INTERVAL_MS=5000

# ── Monitoring ───────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=dte-level5

# ── API Keys (fallback providers) ────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPEN_ROUTER_API_KEY=

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info
VITE_LOG_LEVEL=debug
